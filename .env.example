# Solana RPC (default public endpoint, recommend Helius/Quicknode for production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Shyft GraphQL API — for on-chain position data
SHYFT_API_KEY=your_shyft_key_here

# Helius — enhanced Solana RPC
HELIUS_API_KEY=your_helius_key_here

# Birdeye — token prices & analytics
BIRDEYE_API_KEY=your_birdeye_key_here

# Dune Analytics — wallet/pool discovery queries
DUNE_API_KEY=your_dune_key_here

# Meteora DLMM API needs no key — rate limited to 30 RPS

# Agent config
RISK_PROFILE=moderate
MIN_WALLET_SCORE=60
